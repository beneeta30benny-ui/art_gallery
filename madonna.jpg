ue\":{\"default_average_monthly_credits_per_member\":400},\"is_device_based\":false,\"passed\":false},\"3941338778\":{\"name\":\"3941338778\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabledConnectors\":[],\"enabled\":false},\"is_device_based\":false,\"passed\":false},\"1521940286\":{\"name\":\"1521940286\",\"rule_id\":\"2dprGiDHsVr2AQRVuaPGLU\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":false},\"is_device_based\":false,\"group_name\":\"Control\",\"is_experiment_active\":true,\"is_user_in_experiment\":true},\"2391622925\":{\"name\":\"2391622925\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"self_serve_business_access_token_creation_enabled\":true,\"use_backend_generated_jwt\":true,\"configuration_url\":\"https://chatgpt.com/admin\"},\"is_device_based\":false,\"passed\":false},\"2328308563\":{\"name\":\"2328308563\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"label\":\"manage_cookies\",\"showOptOutIcon\":false},\"is_device_based\":true,\"passed\":false},\"3861898381\":{\"name\":\"3861898381\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"max_file_uploads\":20},\"is_device_based\":false,\"passed\":false},\"1977158438\":{\"name\":\"1977158438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enable_web_search\":false,\"system_prompt\":\"The user is asking about an ad shown to them by {advertiser}. Your response must be about the ad shown. They are using the \\\"Ask ChatGPT\\\" feature to get ChatGPT's honest opinion on the product(s) in the advertisement, and in which situations it could be a great fit for them. You should be honest about when you think the product(s) would vs. would not be useful for the user, based on what you know about them.\\n\\nInformation about the ad:\\n{ad}.\\n\\nStructure your response in the following manner:\\n- Briefly describe the type of user, use case, or situation where this ad/product makes sense for the user.\\n- If appropriate, explain any mismatches with the user's stated preferences or goals. That is, where might it fall short for the user (if appropriate)? You don't have to do this for every query, but feel free to list limitations if you think they're pretty relevant.\\n- Give a concise recommendation (e.g., \\\"worth considering,\\\" \\\"probably not ideal,\\\" \\\"good budget option,\\\" \\\"seriously may be a fit,\\\" etc.)\\n\\nGuidelines:\\n- Be honest and practical.\\n- Do not blindly promote the ad.\\n- Avoid harsh or absolute negative language.\\n- Do not invent details not present in the ad.\\n- Focus on fit, not feature lists.\\n- If the mark on relevance is clearly missed, feel free to be funny with it and keep it lighthearted. Do not mock the user or advertiser; keep the humor gentle.\\n\\nKeep it concise, direct, and easy to scan.\\n\\n{conversation}\",\"user_prompt_key\":\"good_option\"},\"is_device_based\":false,\"passed\":false},\"3961845717\":{\"name\":\"3961845717\",\"rule_id\":\"6P0BG84pqTgT7X3ZW7I2O:0.00:1\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"styles\":[\"cyberpunk\",\"anime\",\"dramatic-headshot\",\"coloring-book\",\"photo-shoot\",\"retro-cartoon\",\"80s-glam\",\"art-nouveau\",\"synthwave\"]},\"is_device_based\":false,\"passed\":false},\"690090010\":{\"name\":\"690090010\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"id_type\":\"workspace_id\",\"value\":{},\"is_device_based\":false,\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"639781334\":{\"name\":\"639781334\",\"rule_id\":\"layerAssignment\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"is_experiment_active\":true,\"is_user_in_experiment\":false},\"1077309515\":{\"name\":\"1077309515\",\"rule_id\":\"abandoned\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enable